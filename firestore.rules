rules_version = '2';

// Multi-tenant security rules for Fieldsta.
//
// Every top-level business document (customers, jobs, technicians, etc.)
// carries a `companyId` field. A signed-in user's own `users/{uid}` doc
// says which company they belong to and what role they have there
// ("owner" | "admin" | "technician"). All reads/writes to company data
// are gated on the requester's `users/{uid}.companyId` matching the
// document's `companyId`.
//
// Deploy with: firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function myCompanyId() {
      return myProfile().companyId;
    }

    function myRole() {
      return myProfile().role;
    }

    function isCompanyMember(companyId) {
      return isSignedIn() && myCompanyId() == companyId;
    }

    function isCompanyAdmin(companyId) {
      return isCompanyMember(companyId) && myRole() in ["owner", "admin"];
    }

    // A resource's companyId can never be changed by an update.
    function companyIdUnchanged() {
      return request.resource.data.companyId == resource.data.companyId;
    }

    // Billing/plan fields on a company doc are only ever written by the
    // Stripe webhook (Admin SDK, bypasses these rules entirely) or by hand
    // in the Firestore console for comped accounts — never by a client
    // update, so an admin can't just grant themselves a free/active plan.
    function planFieldsUnchanged() {
      return request.resource.data.plan == resource.data.plan &&
        request.resource.data.trialEndsAt == resource.data.trialEndsAt &&
        request.resource.data.stripeCustomerId == resource.data.stripeCustomerId &&
        request.resource.data.stripeSubscriptionId == resource.data.stripeSubscriptionId;
    }

    // Lets an existing company (one that skipped the access-code field at
    // signup) redeem one later from /billing. Only allowed from "trial" —
    // an already-comped/active/past_due company can't use this path — and
    // only to a live, unused code, same validation as at creation time.
    // trialEndsAt/Stripe fields still can't move through this path.
    function redeemingAccessCode() {
      return resource.data.plan == "trial" &&
        request.resource.data.plan == "comped" &&
        request.resource.data.accessCodeUsed is string &&
        get(/databases/$(database)/documents/accessCodes/$(request.resource.data.accessCodeUsed)).data.active == true &&
        request.resource.data.trialEndsAt == resource.data.trialEndsAt &&
        request.resource.data.stripeCustomerId == resource.data.stripeCustomerId &&
        request.resource.data.stripeSubscriptionId == resource.data.stripeSubscriptionId;
    }

    // ---------------------------------------------------------------
    // Companies + invites
    // ---------------------------------------------------------------
    match /companies/{companyId} {
      // A new company can only ever set itself up on the standard trial —
      // UNLESS it's redeeming a live, unused access code, in which case it
      // can start out "comped" instead. Either way, a client can never just
      // write plan: "active" directly (that's Stripe-webhook-only), and
      // after creation planFieldsUnchanged() below locks these fields down
      // entirely except via the webhook or a manual console edit.
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid &&
        (
          request.resource.data.plan == "trial" ||
          (
            request.resource.data.plan == "comped" &&
            request.resource.data.accessCodeUsed is string &&
            get(/databases/$(database)/documents/accessCodes/$(request.resource.data.accessCodeUsed)).data.active == true
          )
        );
      allow read: if isCompanyMember(companyId);
      allow update: if isCompanyAdmin(companyId) && (planFieldsUnchanged() || redeemingAccessCode());
      allow delete: if isCompanyAdmin(companyId);

      // Referral records — written server-side only (Admin SDK, via the
      // Stripe webhook, when a company someone referred converts to a paid
      // plan). The referrer can read their own list to see who they've
      // brought in; nothing about it is ever client-writable, so there's no
      // way to fake a referral credit.
      match /referrals/{referredCompanyId} {
        allow read: if isCompanyMember(companyId);
        allow write: if false;
      }

      match /invites/{email} {
        // A prospective teammate needs to read their own invite to join;
        // admins can read/manage all invites for their company.
        allow get: if isCompanyAdmin(companyId) ||
          (isSignedIn() && request.auth.token.email.lower() == email);
        allow list: if isCompanyAdmin(companyId);
        allow create, delete: if isCompanyAdmin(companyId);
        // Deleting your own invite happens as part of joining.
        allow delete: if isSignedIn() && request.auth.token.email.lower() == email;
      }
    }

    // ---------------------------------------------------------------
    // Access codes — one-time-use codes that grant a new company free
    // ("comped") access instead of the standard trial. Codes are created
    // and deleted only by hand in the Firebase console (never by a
    // client) — see README "Access codes" for how. A client can read a
    // code to validate it during company setup, and can flip it from
    // active to inactive to "spend" it, but can't create, delete, or
    // reactivate one, and can't touch anything but the active flag.
    // ---------------------------------------------------------------
    match /accessCodes/{code} {
      allow get: if isSignedIn();
      allow list: if false;
      allow update: if isSignedIn() &&
        resource.data.active == true &&
        request.resource.data.active == false;
      allow create, delete: if false;
    }

    // ---------------------------------------------------------------
    // Users (auth uid -> company + role mapping)
    // ---------------------------------------------------------------
    match /users/{uid} {
      allow read: if isSignedIn() &&
        (request.auth.uid == uid || isCompanyMember(resource.data.companyId));

      // Creating your own profile is only allowed either when:
      //  (a) you're becoming the "owner" of a company you just created, or
      //  (b) you have a pending invite at that company for your email.
      // The `email` field on the new doc must match the caller's own auth
      // token email — otherwise someone could claim a role by writing
      // *someone else's* invited email into their own payload and riding
      // that invite's existence check.
      allow create: if isSignedIn() && request.auth.uid == uid &&
        !exists(/databases/$(database)/documents/users/$(uid)) &&
        request.resource.data.email == request.auth.token.email.lower() &&
        (
          (
            request.resource.data.role == "owner" &&
            get(/databases/$(database)/documents/companies/$(request.resource.data.companyId)).data.ownerUid == request.auth.uid
          ) ||
          (
            request.resource.data.role in ["admin", "technician"] &&
            exists(/databases/$(database)/documents/companies/$(request.resource.data.companyId)/invites/$(request.resource.data.email))
          )
        );

      // Admins can update anything about a member (including role) except
      // moving them to a different company. A user updating their own doc
      // can change non-privilege fields (name, etc.) but can NOT change
      // their own role or companyId — that would be self-promotion.
      allow update: if isCompanyAdmin(resource.data.companyId) && companyIdUnchanged();
      allow update: if isSignedIn() && request.auth.uid == uid &&
        companyIdUnchanged() &&
        request.resource.data.role == resource.data.role;

      allow delete: if isCompanyAdmin(resource.data.companyId);
    }

    // ---------------------------------------------------------------
    // Company-scoped business collections
    // ---------------------------------------------------------------
    match /customers/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isSignedIn() && request.resource.data.companyId == myCompanyId();
      allow update, delete: if isCompanyMember(resource.data.companyId) && companyIdUnchanged();
    }

    match /equipment/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isSignedIn() && request.resource.data.companyId == myCompanyId();
      allow update, delete: if isCompanyMember(resource.data.companyId) && companyIdUnchanged();
    }

    // Technicians and Price Book are admin-managed in the UI (behind
    // AdminRoute) — enforce that at the rules layer too, not just in the
    // client, since a direct Firestore call would otherwise bypass it.
    match /technicians/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyAdmin(myCompanyId()) && request.resource.data.companyId == myCompanyId();
      allow update, delete: if isCompanyAdmin(resource.data.companyId) && companyIdUnchanged();
    }

    match /jobs/{jobId} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isSignedIn() && request.resource.data.companyId == myCompanyId();
      allow update, delete: if isCompanyMember(resource.data.companyId) && companyIdUnchanged();

      match /activity/{activityId} {
        allow read: if isCompanyMember(get(/databases/$(database)/documents/jobs/$(jobId)).data.companyId);
        allow create: if isSignedIn() &&
          request.resource.data.companyId == myCompanyId() &&
          get(/databases/$(database)/documents/jobs/$(jobId)).data.companyId == myCompanyId();
      }
    }

    match /storeOrders/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isSignedIn() && request.resource.data.companyId == myCompanyId();
      allow update, delete: if isCompanyMember(resource.data.companyId) && companyIdUnchanged();
    }

    match /priceBook/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyAdmin(myCompanyId()) && request.resource.data.companyId == myCompanyId();
      allow update, delete: if isCompanyAdmin(resource.data.companyId) && companyIdUnchanged();
    }

    match /estimates/{id} {
      // Public read (not just company members) so a customer can open their
      // own estimate link (/estimate/{id}) without an account — same
      // unguessable-Firestore-ID tradeoff already accepted for /portal.
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.companyId == myCompanyId();
      allow update: if (isCompanyMember(resource.data.companyId) && companyIdUnchanged()) || customerSigning();
      allow delete: if isCompanyMember(resource.data.companyId);
    }

    // Lets an anonymous customer (link only, no account) sign an estimate
    // exactly once: the doc must not already have a signature, and the
    // write can only touch the specific fields a signature needs to set —
    // nothing else about the estimate (line items, prices, companyId) can
    // move through this path.
    function customerSigning() {
      return resource.data.customerSignature == null &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["status", "selectedTier", "customerSignature", "signedByName", "signedAt"]) &&
        request.resource.data.customerSignature is string &&
        request.resource.data.customerSignature.size() > 0 &&
        request.resource.data.status == "accepted";
    }

    match /routes/{routeId} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isSignedIn() && request.resource.data.companyId == myCompanyId();
      allow update, delete: if isCompanyMember(resource.data.companyId) && companyIdUnchanged();
    }

    match /maintenanceAgreements/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isSignedIn() && request.resource.data.companyId == myCompanyId();
      allow update, delete: if isCompanyMember(resource.data.companyId) && companyIdUnchanged();
    }

    // Public online booking requests — anyone with a company's /book/{id}
    // link (shared on their website, no login) can submit a request. Only
    // the company itself can ever read/manage the list; a stranger can
    // create a request but can't see anyone else's.
    match /bookingRequests/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if request.resource.data.companyId is string &&
        exists(/databases/$(database)/documents/companies/$(request.resource.data.companyId)) &&
        request.resource.data.status == "new";
      allow update, delete: if isCompanyMember(resource.data.companyId) && companyIdUnchanged();
    }

    // ---------------------------------------------------------------
    // Customer self-service portal — intentionally public.
    // Access is via an unguessable random token used as the doc ID,
    // not by companyId. Anyone with the link can view; only signed-in
    // users (the company generating it) can create/update snapshots.
    // ---------------------------------------------------------------
    match /portal/{token} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ---------------------------------------------------------------
    // Marketplace concierge MVP (Perth Amboy pilot) — a homeowner submits a
    // job request, a contractor submits their info to be in the pool.
    // Public write, no read: matching is done by hand for now (see chat —
    // the founder texts/calls contractors directly), so the only way this
    // data is ever read back out is the getMarketplaceSubmissions callable
    // (Admin SDK, locked to one account — see functions/index.js), never a
    // direct client query. That also means no one can browse other
    // homeowners' or contractors' submissions.
    // ---------------------------------------------------------------
    match /marketplaceLeads/{id} {
      // A signed-in client can read/list their own past requests (their
      // "history" — see Dashboard.jsx); anyone else's data still only
      // comes out through the owner-locked getMarketplaceSubmissions
      // callable. Guest (signed-out) submissions are still allowed on
      // create for backward compatibility, they just won't show up in
      // anyone's dashboard since there's no uid to query by.
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.phone is string &&
        request.resource.data.phone.size() > 0 &&
        request.resource.data.status == "new" &&
        (!("uid" in request.resource.data) || request.resource.data.uid == request.auth.uid);
      allow update, delete: if false;
    }

    match /marketplaceContractors/{id} {
      allow read: if false;
      allow create: if request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.phone is string &&
        request.resource.data.phone.size() > 0 &&
        (!("uid" in request.resource.data) || request.resource.data.uid == request.auth.uid);
      allow update, delete: if false;
    }

    // A contractor's bid on a specific job request (marketplaceLeads doc).
    // A signed-in contractor can read their own bids back (their "history"
    // in Dashboard.jsx); nobody can read anyone else's bids on a job
    // directly — that only comes out through getMarketplaceSubmissions.
    match /marketplaceBids/{id} {
      allow read: if isSignedIn() && resource.data.contractorUid == request.auth.uid;
      allow create: if request.resource.data.leadId is string &&
        request.resource.data.leadId.size() > 0 &&
        request.resource.data.contractorName is string &&
        request.resource.data.contractorName.size() > 0 &&
        request.resource.data.contractorPhone is string &&
        request.resource.data.contractorPhone.size() > 0 &&
        request.resource.data.amount is number &&
        request.resource.data.amount > 0 &&
        (!("contractorUid" in request.resource.data) || request.resource.data.contractorUid == request.auth.uid);
      allow update, delete: if false;
    }

    // A marketplace user's profile: role(s) — client, contractor, or both
    // — plus contact info. Only the account owner can ever read or write
    // it; nobody else, including other marketplace users, can see it.
    match /marketplaceProfiles/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // ---------------------------------------------------------------
    // Public site analytics — a single doc (siteAnalytics/welcome) that
    // anyone (signed in or not) can increment by exactly 1 when the
    // Welcome page loads. Write-only from the client: the aggregate is
    // only ever read back out via the getGrowthStats callable (Admin SDK,
    // bypasses these rules), never directly by a client, so nobody can
    // see the raw counter or tamper with it beyond bumping it by one.
    // ---------------------------------------------------------------
    match /siteAnalytics/{docId} {
      allow read: if false;
      allow create: if request.resource.data.keys().hasOnly(["visits"]) &&
        request.resource.data.visits == 1;
      allow update: if resource.data.keys().hasOnly(["visits"]) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["visits"]) &&
        request.resource.data.visits == resource.data.visits + 1;
      allow delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
